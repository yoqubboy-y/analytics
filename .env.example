APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

TARGET_ANALYTICS_DB_URL=postgresql://postgres:gjJTJsPpwzabCmaunVxglfyZgipdZGjP@centerbeam.proxy.rlwy.net:22118/postgres

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Disk used to stage parsed XLSX payloads before the worker picks them up.
# Use `local` for single-host dev. For multi-container deploys (Railway,
# ECS, etc.) set this to `s3` so the web pod and the worker pod share storage,
# and populate the AWS_* vars below.
IMPORTS_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no_reply@rooler.ai"
MAIL_FROM_NAME="Rooler"

RESEND_API_KEY=

# S3-compatible storage for XLSX import staging (and other cloud-disk needs).
# For AWS S3: leave AWS_ENDPOINT empty and AWS_USE_PATH_STYLE_ENDPOINT=false.
# For Cloudflare R2 / DigitalOcean Spaces / Backblaze B2: set AWS_ENDPOINT to
# the bucket's API endpoint and AWS_USE_PATH_STYLE_ENDPOINT=true.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# AI assistant (Laravel AI SDK). The in-app chatbot talks to models through
# OpenRouter; users pick any tool-capable model from the OpenRouter catalogue.
OPENROUTER_API_KEY=
AI_CHAT_MODEL=openai/gpt-4o-mini
# Cheap model used for background work such as generating chat titles.
AI_CHAT_TITLE_MODEL=openai/gpt-4o-mini
# Public Mapbox token (pk.*) so the assistant can draw route maps in chat.
MAPBOX_TOKEN=

VITE_APP_NAME="${APP_NAME}"
